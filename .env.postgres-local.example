APP_NAME=Pyrragi
APP_ENV=local
SECRET_KEY=local-dev-only

# Full local mode: install/start PostgreSQL and Redis on the host.
DATABASE_URL=postgresql+psycopg://pyrragi:pyrragi@localhost:5432/pyrragi
REDIS_URL=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=true

ARCHIVE_DIR=./storage/archives
THUMB_DIR=./storage/thumbs
CACHE_DIR=./storage/cache
MAX_UPLOAD_MB=2048
